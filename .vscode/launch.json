    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Fable with Vite",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "dotnet",
            "runtimeArgs": [
                "fable",
                "watch",
                "--lang",
                "javascript",
                "--verbose",
                "--exclude",
                "Oxpecker.Solid.FablePlugin",
                "--extension",
                ".jsx",
                "--run",
                "npx",
                "vite"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}